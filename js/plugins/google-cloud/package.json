{
  "name": "@genkit-ai/google-cloud",
  "description": "Genkit AI framework plugin for Google Cloud Platform including Firestore trace/state store and deployment helpers for Cloud Functions for Firebase.",
  "keywords": [
    "genkit",
    "genkit-plugin",
    "genkit-telemetry",
    "genkit-deploy",
    "genkit-flow",
    "google cloud",
    "google cloud platform",
    "ai",
    "genai",
    "generative-ai"
  ],
  "version": "1.34.0",
  "type": "commonjs",
  "scripts": {
    "check": "tsc",
    "compile": "tsup-node",
    "build:clean": "rimraf ./lib",
    "build": "npm-run-all build:clean check compile",
    "build:watch": "tsup-node --watch",
    "test": "node node_modules/jest/bin/jest --runInBand --verbose"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/genkit-ai/genkit.git",
    "directory": "js/plugins/google-cloud"
  },
  "author": "genkit",
  "license": "Apache-2.0",
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.0",
    "@google-cloud/modelarmor": "^0.5.0",
    "@google-cloud/opentelemetry-cloud-monitoring-exporter": "^0.21.0",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/opentelemetry-resource-util": "^3.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/core": "~2.7.1",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-pino": "^0.64.0",
    "@opentelemetry/instrumentation-winston": "^0.62.0",
    "@opentelemetry/resources": "~2.7.1",
    "@opentelemetry/sdk-metrics": "~2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "~2.7.1",
    "google-auth-library": "^10.6.2",
    "node-fetch": "^3.3.2",
    "winston": "^3.12.0"
  },
  "peerDependencies": {
    "genkit": "workspace:^"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.10",
    "tsup": "^8.3.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "require": "./lib/index.js",
      "import": "./lib/index.mjs",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./model-armor": {
      "require": "./lib/model-armor.js",
      "import": "./lib/model-armor.mjs",
      "types": "./lib/model-armor.d.ts",
      "default": "./lib/model-armor.js"
    }
  },
  "typesVersions": {
    "*": {
      "model-armor": [
        "lib/model-armor"
      ]
    }
  }
}
