{
  "name": "@genkit-ai/a2ui",
  "version": "0.0.1",
  "description": "A Genkit plugin providing A2UI (Agent-to-UI) streaming UI protocol support via model middleware.",
  "keywords": [
    "genkit",
    "genkit-plugin",
    "a2ui",
    "agent-ui",
    "generative-ui",
    "streaming",
    "agents",
    "ai",
    "genai",
    "generative-ai"
  ],
  "homepage": "https://github.com/genkit-ai/genkit/tree/main/js/plugins/a2ui#readme",
  "bugs": {
    "url": "https://github.com/genkit-ai/genkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/genkit-ai/genkit.git",
    "directory": "js/plugins/a2ui"
  },
  "license": "Apache-2.0",
  "author": "genkit",
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "require": "./lib/index.js",
      "import": "./lib/index.mjs",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./client": {
      "require": "./lib/client.js",
      "import": "./lib/client.mjs",
      "types": "./lib/client.d.ts",
      "default": "./lib/client.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "lib/client"
      ]
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc",
    "compile": "tsup-node",
    "build:clean": "rimraf ./lib",
    "build": "npm-run-all build:clean check compile",
    "build:watch": "tsup-node --watch",
    "test": "tsx --test ./tests/*_test.ts"
  },
  "peerDependencies": {
    "genkit": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "genkit": "workspace:*",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
