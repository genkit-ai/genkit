{
  "name": "@genkit-ai/next",
  "description": "Next.js plugin for Genkit",
  "keywords": [
    "genkit",
    "genkit-plugin",
    "google cloud",
    "google ai",
    "ai",
    "genai",
    "generative-ai",
    "next",
    "nextjs",
    "next.js",
    "react"
  ],
  "version": "1.34.0",
  "type": "commonjs",
  "main": "lib/index.js",
  "scripts": {
    "check": "tsc",
    "compile": "tsup-node",
    "build:clean": "rimraf ./lib",
    "build": "npm-run-all build:clean check compile",
    "build:watch": "tsup-node --watch",
    "test": "jest --verbose"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/genkit-ai/genkit.git",
    "directory": "js/plugins/next"
  },
  "author": "genkit",
  "license": "Apache-2.0",
  "peerDependencies": {
    "genkit": "workspace:*",
    "next": "^15.0.0 || ^16.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "genkit": "workspace:*",
    "jest": "^30.4.2",
    "next": "^16.2.6",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.10",
    "tsup": "^8.0.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "require": "./lib/index.js",
      "import": "./lib/index.mjs",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./client": {
      "require": "./lib/client.js",
      "import": "./lib/client.mjs",
      "types": "./lib/client.d.ts",
      "default": "./lib/client.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "lib/client"
      ]
    }
  }
}
