{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "lib": ["es2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "lib",
    "rootDir": "src",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["web", "node_modules", "lib"]
}
