{
  "name": "a2ui-testapp",
  "version": "1.0.0",
  "private": true,
  "description": "Testapp demonstrating @genkit-ai/a2ui: an agent that streams A2UI surfaces to a Lit renderer.",
  "main": "lib/index.js",
  "scripts": {
    "build:web": "cd web && pnpm run build",
    "build": "tsc && pnpm run build:web",
    "start": "pnpm run build:web && tsx src/index.ts",
    "server": "tsx src/index.ts",
    "web:dev": "cd web && pnpm run dev",
    "dev": "tsx --watch src/index.ts",
    "genkit:dev": "genkit start -- tsx src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@genkit-ai/a2ui": "workspace:*",
    "@genkit-ai/express": "workspace:*",
    "@genkit-ai/google-genai": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "genkit": "workspace:*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
