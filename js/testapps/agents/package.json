{
  "name": "agents-testapp",
  "version": "1.0.0",
  "description": "Testapp for Genkit Agents",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:web": "cd web && pnpm run build",
    "server": "npx tsx src/index.ts",
    "start": "pnpm run build:web && npx tsx src/index.ts",
    "web:dev": "cd web && pnpm run dev",
    "genkit:dev": "genkit start -- npx tsx --watch src/index.ts"
  },
  "dependencies": {
    "@genkit-ai/anthropic": "workspace:*",
    "@genkit-ai/compat-oai": "workspace:*",
    "@genkit-ai/express": "workspace:*",
    "@genkit-ai/google-genai": "workspace:*",
    "@genkit-ai/middleware": "workspace:*",
    "@genkit-ai/vertexai": "workspace:*",
    "express": "^4.22.2",
    "genkit": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "typescript": "^5.9.3"
  }
}
