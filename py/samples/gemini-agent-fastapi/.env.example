GEMINI_API_KEY=
JWT_SECRET=dev-only-change-me
# A datastore is required. Set FIREBASE_PROJECT_ID when deployed, or point at the
# Firestore emulator locally (FIRESTORE_EMULATOR_HOST + GOOGLE_CLOUD_PROJECT).
FIREBASE_PROJECT_ID=
FIRESTORE_EMULATOR_HOST=localhost:8080
GOOGLE_CLOUD_PROJECT=demo-local
AUTH_DEV_MODE=true
GENKIT_ENV=dev
CORS_ORIGINS=*
